#################################################################
#    Annotations
#################################################################

:SCOSy_0000001 rdfs:label "functional system"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A system whose components play different functional roles with respect to the whole system."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


:SCOSy_0000002 rdfs:label "functional complex system"@en ;
               <http://www.w3.org/2004/02/skos/core#definition> "A complex system whose components play different functional roles with respect to the whole complex system."@en ;
               <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


:SCOSy_0000003 rdfs:label "functional system component"@en ;
               <http://www.w3.org/2004/02/skos/core#definition> "A system component that is part of a functional system."@en ;
               <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


:SCOSy_0000004 rdfs:label "functional complex system component"@en ;
               <http://www.w3.org/2004/02/skos/core#definition> "A complex system component that is part of a functional complex system."@en ;
               <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


:SCOSy_0000005 rdfs:comment "The meaning of the relation between the external entitles and the system should be further discussed. This may be model as participation of interactions between complex system components and components of the related environment."@en ;
               rdfs:label "complex system environment component - system related"@en ;
               <http://www.w3.org/2004/02/skos/core#definition> "A complex system environment component that is related to the corresponding complex system."@en ;
               <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional> .


:SCOSy_0000006 rdfs:label "disposition to act of a system component"@en ;
               <http://www.w3.org/2004/02/skos/core#definition> "A disposition to act that inheres in some system component." ;
               <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


:SCOSy_0000007 rdfs:label "disposition of a system component to participate in an interaction"@en ;
               <http://www.w3.org/2004/02/skos/core#definition> "A disposition to participate in an interaction that inheres in some system component."@en ;
               <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


